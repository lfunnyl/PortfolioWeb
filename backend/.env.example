# .env.example — Bu dosya güvenle Git'e eklenebilir (gerçek değer içermez)
# Kopyala ve gerçek değerlerle doldur: cp .env.example .env

# ─── Kimlik Doğrulama ────────────────────────────────────────────────────────
# Güçlü rastgele anahtar üret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-strong-random-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Veritabanı ────────────────────────────────────────────────────────────
# Yerel geliştirme için SQLite:
DATABASE_URL=sqlite:///./portfolio_v2.db
# Railway PostgreSQL için (Railway bu değeri otomatik verir):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── CORS (İzin Verilen Originler) ──────────────────────────────────────────
# Virgülle ayırarak birden fazla eklenebilir
# Yerel geliştirme:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
# Production (Vercel URL'ini ekle):
# ALLOWED_ORIGINS=https://sening-proje.vercel.app

# ─── Ortam ─────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Production için: ENVIRONMENT=production

# ─── Haber API'si ──────────────────────────────────────────────────────────
MARKETAUX_API_KEY=

# ─── E-posta (SMTP) ─────────────────────────────────────────────────────────
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@portfolioweb.app
MAIL_FROM_NAME=PortfolioWeb
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ─── Frontend URL ───────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Production için: FRONTEND_URL=https://sening-proje.vercel.app
